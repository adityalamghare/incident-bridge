# incident-bridge — environment variables (FireHydrant Command Extension edition)
# Deploy this service SEPARATELY from SkillHub, on an ALWAYS-ON host
# (Render/Railway/Fly) — it runs a setInterval heartbeat, so not serverless.

# --- SkillHub health (what the heartbeat checks) ---
# The URL the bridge pings every 30s. Use /health if it exists, else the home page.
SKILLHUB_HEALTH_URL=https://skillhub-rosy.vercel.app/health

# --- FireHydrant ---
# Heartbeat ping URL from FireHydrant > Signals > Heartbeats.
# The bridge POSTs here ONLY when SkillHub is healthy; silence = FireHydrant alerts.
FH_HEARTBEAT_URL=
# Signing key set on the FireHydrant Webhook Alert Target (verifies inbound webhook calls).
FH_WEBHOOK_SIGNING_KEY=
# Signing secret set on the FireHydrant Command Extension (verifies inbound /rollback calls).
FH_COMMAND_SIGNING_SECRET=

# --- Vercel ---
# Account token (Vercel > Account Settings > Tokens), scoped to the SkillHub project.
VERCEL_TOKEN=
# SkillHub's project ID and (if on a team) team ID, from Project Settings.
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
# RECOMMENDED for demos: pin the known-good deployment ID to roll back to.
# Leave blank to auto-detect the previous production deployment.
GOOD_DEPLOYMENT_ID=

# Port (most hosts set this automatically).
PORT=3000
